# Prefer the newer API key path when available.
DOUBAO_API_KEY=replace-with-doubao-api-key

# Legacy app credentials are still supported for older console setups.
DOUBAO_APP_ID=
DOUBAO_APP_KEY=
DOUBAO_ACCESS_KEY=

DOUBAO_AST_RESOURCE_ID=volc.service_type.10053
# Optional; Doubao simultaneous interpretation 2.0 does not currently require a model ID.
DOUBAO_AST_MODEL_ID=
DOUBAO_AUC_RESOURCE_ID=volc.bigasr.auc_turbo
DATABASE_URL=runtime/agent-dance.db
UPLOAD_DIR=uploads
HTTP_ADDR=:8080
HTTP_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
